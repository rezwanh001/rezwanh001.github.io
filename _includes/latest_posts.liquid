<div class="latest-posts">
  {% if site.latest_posts != blank %}
    {% assign latest_posts_size = site.posts | size %}
    <div
      class="posts-list"
      {% if site.latest_posts.scrollable and latest_posts_size > 3 %}
        style="max-height: 420px; overflow-y: auto;"
      {% endif %}
    >
      {% assign latest_posts = site.posts %}
      {% if site.latest_posts.limit %}
        {% assign latest_posts_limit = site.latest_posts.limit %}
      {% else %}
        {% assign latest_posts_limit = latest_posts_size %}
      {% endif %}
      {% for item in latest_posts limit: latest_posts_limit %}
        <div class="post-item">
          <div class="post-date">
            <span class="post-date-day">{{ item.date | date: '%d' }}</span>
            <span class="post-date-month">{{ item.date | date: '%b %Y' }}</span>
          </div>
          <div class="post-content">
            {% if item.redirect == blank %}
              <a class="post-link" href="{{ item.url | relative_url }}">{{ item.title }}</a>
            {% elsif item.redirect contains '://' %}
              <a class="post-link" href="{{ item.redirect }}" target="_blank">
                {{ item.title }}
                <i class="fas fa-external-link-alt" style="font-size:0.65rem; margin-left:0.3rem; opacity:0.5;"></i>
              </a>
            {% else %}
              <a class="post-link" href="{{ item.redirect | relative_url }}">{{ item.title }}</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p>No posts so far...</p>
  {% endif %}
</div>
