---
layout: default
---
<div class="post">
  <header class="post-header about-header-row">
    {% if page.profile and page.profile.image %}
      <div class="about-header-image">
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        {% if page.profile.image_circular %}
          {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
        {% else %}
          {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
        {% endif %}
        {% capture sizes %}(min-width: {{site.max_width}}) 180px, (min-width: 576px) 180px, 160px{% endcapture %}
        {%
          include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
          cache_bust=true
        %}
      </div>
    {% endif %}
    <div class="about-header-info">
      <h1 class="post-title">
        {% if site.title == 'blank' %}
          {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>
      <p class="desc">{{ page.subtitle }}</p>
      {% if page.social %}
        <div class="about-header-social">
          <div class="contact-icons">{% include social.liquid %}</div>
        </div>
      {% endif %}

      {% assign scholar_stats = site.data.scholar %}
      {% if page.citation and scholar_stats and scholar_stats.citations %}
        <div class="about-header-citations">
          <a
            href="https://scholar.google.com/citations?user={{ site.scholar_userid | default: site.data.socials.scholar_userid }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Google Scholar citation metrics"
          >
            <img
              src="https://img.shields.io/badge/dynamic/yaml?url=https%3A%2F%2Fraw.githubusercontent.com%2Frezwanh001%2Frezwanh001.github.io%2Fmaster%2F_data%2Fscholar.yml&query=citations.all&label=Google%20Scholar%20Citations&color=4285F4&logo=googlescholar&logoColor=white"
              alt="Google Scholar Citations: {{ scholar_stats.citations.all }}"
            >
          </a>
          <span class="about-header-citation-summary">
            h-index {{ scholar_stats.h_index.all }} · i10-index {{ scholar_stats.i10_index.all }}
          </span>
        </div>
      {% endif %}
    </div>
  </header>

  <article>
    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <div class="about-section about-news-section">
        <div class="about-section-header">
          <i class="fas fa-bullhorn"></i>
          <h2><a href="{{ '/news/' | relative_url }}">News</a></h2>
        </div>
        {% include news.liquid limit=true %}
      </div>
    {% endif %}

    <!-- Latest posts -->
    {% if site.latest_posts.enabled %}
      <div class="about-section about-posts-section">
        <div class="about-section-header">
          <i class="fas fa-feather-pointed"></i>
          <h2><a href="{{ '/blog/' | relative_url }}">Latest Posts</a></h2>
        </div>
        {% include latest_posts.liquid %}
      </div>
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <div class="about-section about-pubs-section">
        <div class="about-section-header">
          <i class="fas fa-award"></i>
          <h2><a href="{{ '/publications/' | relative_url }}">Selected Publications</a></h2>
        </div>
        {% include selected_papers.liquid %}
      </div>
    {% endif %}

    {% if site.newsletter.enabled and site.footer_fixed %}
      {% include scripts/newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
